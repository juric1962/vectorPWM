#include <stdint.h>

#define ROM_COMMAND_READ_ROM 0x33
#define ROM_COMMAND_MATCH_ROM 0x55
#define ROM_COMMAND_READ_SCRATCHPAD 0xBE
#define ROM_COMMAND_CONVERT_T 0x44

#define DS18B20_MUX_A(a) HAL_GPIO_WritePin(GPIOE, GPIO_PIN_2, (GPIO_PinState)a) 
#define DS18B20_MUX_B(a) HAL_GPIO_WritePin(GPIOE, GPIO_PIN_3, (GPIO_PinState)a) 
#define DS18B20_MUX_C(a) HAL_GPIO_WritePin(GPIOE, GPIO_PIN_4, (GPIO_PinState)a) 

typedef struct{
uint8_t familyCode;
uint8_t serNum[6];
uint8_t CRC8; 
}DS18B20_FACTORY_CODE_STRUCT;

typedef struct{
 DS18B20_FACTORY_CODE_STRUCT DS18B20_Code; 
 uint8_t scratchPad[9];
 int8_t curTemp;
 uint8_t errorCode;    
 uint16_t errorNum;   
 uint8_t isOn;       // нОПНЯ ДЮРВХЙЮ ЛНФМН НРЙКЧВХРЭ: 0 - НРЙКЧВЕМ, 1 - БЙКЧВЕМ
}TEMP_SENSOR;
extern volatile TEMP_SENSOR tempSensor[2];

uint8_t DS18B20_Init(void);
void DS18B20_Write(uint8_t *src, uint8_t len);
void DS18B20_Read(uint8_t *dst, uint8_t len);
void DS18B20ReadROM(uint8_t *output);
void tempSensorsInit(void);
void getTemperatureTask(void);