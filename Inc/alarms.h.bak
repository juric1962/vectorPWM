#include "stm32f4xx_hal.h"

// Список событий для работы в режиме автоматического повторного запуска
#define BRIDGE_SATURATION_FAULT     6    //#define INST_OVERCURRENT_FAULT      1 // #define RMS_OVERCURRENT_FAULT,  
#define UDC_OVERVOLTAGE_FAULT       5       
#define ETR_OVERLOAD_FAULT          4
#define BREAK_PHASE_CURRENT_FAULT   3 // #define CURRENT_DISBALANCE_FAULT  
#define TEMP_SENS_FAULT             2
#define LOW_VOLTAGE_FAULT           1
#define NO_LOAD_FAULT               0

#define FAULT_ARRAY_ITEMS_NUM 7       // Общее количество событий для работы в режиме автоматического повторного запуска (АПВ)
typedef struct{
  uint16_t upCnt;            // Инкрементируемый счетчик аварии, при достяжении нуля - автоматический повтороный пуск запрещен 
  uint16_t maxCnt;           // Максимальное значение инкрементируемого счетчика
  uint16_t recoverCntMin;    // Секундный счетчик, отвечающий за декрементацию счетчика аварий upCnt в случае его переполнения     
  uint32_t recoverTime;      // Временная метка, выставляется по конкретной аварии, при сравнении с текущем временем принимается решение о декрементировании счетчика upCnt  
  uint16_t CRC16;            // Контрольная сумма структуры, т.к. время работы с самой надежной в нашей системе FRAM-памятью медленное, запись одного байта примерно 10 мкс, то буду сохранять каждое событие отдельно 
}FAULT_EVENT_STRUCT;         // Структура для автоматического включения, для удобства однообразной отработки аварий 
//extern volatile FAULT_EVENT_STRUCT *faultStruct;//[FAULT_ARRAY_ITEMS]; // Массив событий АПВ
extern volatile FAULT_EVENT_STRUCT *faultsArrayNVRAM;
uint8_t  faultCountersUpdate(uint8_t num); // Обновить состояние счетчиков аварий, с учетом recoverCntSec
uint8_t faultEventAdd(uint8_t num);    // Добавить событие, если функция возвращает не ноль, то выключить двигатель, продолжать работу с ЧРЭП можно только после сброса ошибок при переключении тумблера "АВТО/РУЧН." или через модбас                            
uint32_t faultsInit(void); // Инициализация массива АПВ  
void faultCountersReset(void); 
/*
