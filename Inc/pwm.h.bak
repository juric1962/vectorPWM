typedef struct{
// Start ModBus    
  float minValue[2];  
  float maxValue[2];  
  uint16_t minMV[2];
  uint16_t maxMV[2];  
  uint16_t source[2];  // Источник сигналов АО: 0 - выкл, 1 - Fвых, 2 - об/мин, 3 - Pакт    
// End ModBus
  uint16_t CRC16;  
  uint8_t updateFromShadow;     // Произошло изменение настроек теневой структуры   
  uint16_t minCode[2];  // Код, соотв. minMV
  uint16_t maxCode[2];  // Код, соотв. maxMV
  uint32_t code[2];     // Выходной код для ЦАП 
  float inputValue[2];  // Входная масштабируемя величина (источник сигнала)   
  float k[2];           // Коэффициент k: F=k*adcCode+b
  float b[2];           // Слагаемое b: F=k*adcCode+b 
  float calibr[2];      // Калибровочные коэффициенты...  
}DAC_OUTPUTS_STRUCT;
extern DAC_OUTPUTS_STRUCT dacOutputs,dacOutputsShadow;

typedef struct{
// Start ModBus  
  uint16_t minFreq[2];       // Минимальная частота, соответствующая минимальному коду АЦП
  uint16_t maxFreq[2];       // Максимальная частота, соответствующая максимальному коду АЦП
  uint16_t minMV[2];         // Минимальный код АЦП, соответствующий минимальной частоте
  uint16_t maxMV[2];         // Максимальный код АЦП, соответствующий максимальной частоте
  uint16_t meanMS[4];        // Время фиксации и усреднения уровня напряжения на входе ТИТ (10-10000) мс
  uint16_t dmV[2];           // Разница между двумя усреднениями, при котором считаем сигнал устоявшемся
  uint16_t oneHandrethDF[2]; // Разница в сотых Гц между outPutFreq и command.currentFreqOrRPM, при котором происходит изменение частоты
  // End ModBus 
  uint16_t CRC16;
  uint8_t updateFromShadow;     // Произошло изменение настроек теневой структуры   
  uint16_t minCode[2];
  uint16_t maxCode[2];
  //float mvToCodeCoeff[]
  float k[2];            // Коэффициент k: F=k*adcCode+b
  float b[2];            // Слагаемое b: F=k*adcCode+b
  float df[2];           // oneHandrethDF в Гц
  float outPutValue[2];  // Вычисленная выходная величина (частота, ...)
  uint16_t adcData[4];   // Данные АЦП
  int16_t curMean[4];    // Текущее среднее значение по каналу 
  int16_t prevMean[2];   // Предыдущее среднее по каналу
  uint32_t meanSum[4];   // Сумматор для усреднения 
  uint32_t meanCnt[4];   // Счетчик сумматора для усреднения
  uint32_t meanCntMax[4];// Перевод meanMS в meanCntMax 
  uint8_t Ready[2];
  float calibr[2];
}ADC_INPUTS_STRUCT; 
extern ADC_INPUTS_STRUCT adcInputs, adcInputsShadow; 

extern volatile uint16_t shortCurrentCheck;
void switchPWMtoDO(void);
void switchDOtoPWM(void);