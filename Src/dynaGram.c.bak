#include "dynaGram.h"
#include "main.h"
#include "pwm.h"
#include <arm_math.h>
#include "fram.h"
#include "modbus.h"
#include "sram_rtc.h"
#include "alarms.h"
#include "bvi.h"

uint8_t dynaRawArray[DYNA_RAW_ARRAY_SIZE];
volatile DYNA_GRAM_STRUCT dynaGram;
volatile DYNA_SAMPLE_STRUCT* dynaRawData;
DYNA_OUTPUT_DATA dynaOutputData;
volatile LUFKIN_CARD_FORCE lufkinCardForce;
//volatile LUFKIN_CARD_ACTIVE_POWER lufkinCardActivePower;
volatile DYNAMOGRAM_PLOT dynaPlot;

void dynaGramInit(void)
{  
  framRead(DYNAGRAM_SETTINGS_FRAM_ADDR,(uint8_t*)&dynaGram,DYNAGRAM_SETTINGS_FRAM_LENGTH);   
  if(dynaGram.CRC16!=modBusCRC16((uint8_t*)&dynaGram,DYNAGRAM_SETTINGS_MODBUS_REGNUM*2)) // Загрузка данных по умолчанию, СК-8
  {
    eventsCnt.dynaGramDefaults++;
    systemState.eventLogHardwareFault=16; // Сброс настроек динамограммы
    eventLogWrite(18);    
    dynaGram.l1=2195;
    dynaGram.l2=3000;
    dynaGram.l=3000; 
    dynaGram.KK=2500;
    dynaGram.KK1=3500;
    dynaGram.r=1200;    
    dynaGram.dynagramUpdateSec=30;
    dynaGram.dynagramTimeOutSec=300;
    dynaGram.detectorRetryNum=5;
    dynaGram.minPeriodOfDynagramCycles=40000;    
    dynaGram.tit3SamplesNum=10;
    dynaGram.tit3ToForceCoeff=3.117440f;  
    dynaGram.tit3ToForceConst=-2548.419922f;
    dynaGram.loadMin=600.0f;  
    dynaGram.loadMax=6000.0f;  
    dynaGram.loadMaxMinHoldMS=1000;    
    dynaGram.algorithmFmax=50.0f;
    dynaGram.algorithmFstart=20.0f;
    dynaGram.algorithmFmin=10.0f;  
    dynaGram.algorithmWorkLoadON=800.0f;    
    dynaGram.algorithmWorkLoadOFF=1000.0f;  
    dynaGram.algorithmFreqChange=1.0f;    
    dynaGram.algorithmPumpShift=1500.0f;
    dynaGram.algorithmPumpForce=2500.0f;    
    dynaGram.algorithmPumpRetryNum=0;
    dynaGram.algorithmOn=0;
    dynaGram.testDynagramLoadMax=9000;
    dynaGram.testDynagramLoadMin=1000;
    dynaGram.testDynagramShiftMax=3000;
    dynaGram.testDynagramShiftMin=1000;
    dynaGram.testDynagramRawPointsNum=2500;  
    dynaGram.afterAlarmDelayMin=15;
    dynaGram.slipPercent=10;    
    dynaGram.slipCompensationOn=0;
    dynaGram.CRC16=modBusCRC16((uint8_t*)&dynaGram,DYNAGRAM_SETTINGS_MODBUS_REGNUM*2);     
    framWrite(DYNAGRAM_SETTINGS_FRAM_ADDR,(uint8_t*)&dynaGram,DYNAGRAM_SETTINGS_FRAM_LENGTH);     
  }  
  dynaRawData=(DYNA_SAMPLE_STRUCT*)dynaRawArray;
  //--------- Аварии по датчику нагрузки ---------------------------------------
  if(dynaGram.tit3ToForceCoeff>0.0f)
  {
    dynaGram.loadMinAdcCode=(int16_t)((dynaGram.loadMin-dynaGram.tit3ToForceConst)/dynaGram.tit3ToForceCoeff);  // Код ацп ТИТ3, соответсвующий loadMin tit3=(loadMin-b)/k; если<0, то=0
    if(dynaGram.loadMinAdcCode<0)dynaGram.loadMinAdcCode=0;
    dynaGram.loadMaxAdcCode=(int16_t)((dynaGram.loadMax-dynaGram.tit3ToForceConst)/dynaGram.tit3ToForceCoeff);  // Код ацп ТИТ3, соответсвующий loadMax tit3=(loadMax-b)/k; если>4095, то=4095 
  }
  dynaGram.loadMinMaxHoldCnt=0;    
  dynaGram.loadMinMaxHoldMStoCycles=(engine.freqPWM*dynaGram.loadMaxMinHoldMS)/1000;
  //----------------------------------------------------------------------------    
  dynaGram.state=0; 
  dynaGram.error=0;
  dynaGram.loadAlarmState=0;
  dynaGram.algorithmState=0;  
  dynaGram.updateFreq=0; 
  dynaGram.algorithmWorkLoadState=0;
  dynaGram.beeperOn=0;
  dynaGram.algorithmPumpRetryCntUP=0;  
  dynaGram.algorithmPumpRetryCntDOWN=0;
  dynaGram.voltagePhaseRdy=0;
}

void dynaGramTask() // Обработка сырых данных
{ 
  uint32_t curTick;
  static uint32_t prevTick;   
  uint32_t ms; 
  uint16_t i;
  uint8_t j=0;	    
  float Fa,Fb,Z,tempSqrt,y,psi;  
  int16_t maxActivePower, minActivePower; // Минимальная и максимальная активная мощность за период качания / 2 (Вт)
  uint16_t maxLoad, minLoad;              // Минимальная и максимальная сила на штоке
  int16_t minShift;                       // Минимальное положение головки балансира в мм
  int16_t minShiftSlip;                   // Минимальное положение головки балансира в мм с учетом скольжения 
  int16_t maxShiftLufkin,minShiftLufkin;  // Максимальное и минимальное положение головки балансира в мм  
  static float algorithmDF;               // Изменение частоты при работе алгоритма 
  uint16_t tempUINT16;  
  int32_t prevArgument=0;
  static float dPhi;
  float OMG;
  float syncSpeed;
  
  if(dynaGram.loadAlarmState==1) // Зафиксировать аварию по датчику нагрузки в счетчике и протоколе событий
  {     
    eventLogWrite(25); 
    eventsCnt.dynaGramLoadMin++;
    dynaGram.loadAlarmState=0;
    dynaGram.error|=0x100;
  }else{
    if(dynaGram.loadAlarmState==2)
    {
      eventLogWrite(25); 
      eventsCnt.dynaGramLoadMax++;  
      dynaGram.loadAlarmState=0; 
      dynaGram.error|=0x200;
    }    
  }

  if(dynaGram.algorithmFmin>dynaGram.algorithmFmax){dynaGram.error|=0x04;dynaGram.state=0;}     
  if(dynaGram.algorithmFmin<engine.minFreq){dynaGram.error|=0x08;dynaGram.state=0;}      
  if(dynaGram.algorithmFmax>engine.maxFreq){dynaGram.error|=0x10;dynaGram.state=0;}   
  if(dynaGram.algorithmWorkLoadON>dynaGram.algorithmWorkLoadOFF){dynaGram.error|=0x20;dynaGram.state=0;}            
  
  if(dynaGram.algorithmOn)
  {    
    if(systemState.curMode==1) // Алгоритм изменения частоты в зависимости от динамограммы работает только в режиме ЧРЭП
    {
      if(context.freqSource[context.curContextNum]==0) // Алгоритм изменения частоты в зависимости от динамограммы работает только, когда исчтоник частоты-модбас
      {
       if(dynaGram.beeperOn==0){forceBVI(9,25);dynaGram.beeperOn=1;}
       if(dynaGram.algorithmState==0)
       {
         dynaGram.algorithmState=1; // Установить стартовую частоту 
         dynaGram.algorithmFreq=dynaGram.algorithmFstart;
       }
      }else{
        forceBVI(9,0);
        dynaGram.beeperOn=0;
        if(dynaGram.algorithmState)dynaGram.algorithmState=0;
      } 
    }else{
      forceBVI(9,0);
      dynaGram.beeperOn=0;
      if(dynaGram.algorithmState)dynaGram.algorithmState=0;
    }                   
  }else{  
    if(dynaGram.beeperOn==1)
    {
      forceBVI(9,0);
      dynaGram.beeperOn=0;    
    }           
    if(dynaGram.algorithmState)dynaGram.algorithmState=0;     
  }
  
  if(vectorPWM.isOn==0)dynaGram.state=0;
  switch(dynaGram.state)
  {
    case 0:
      dynaGram.TC10retryCnt=0;
      dynaGram.testDynagramRawPointsCnt=0;
      dynaGram.rawDataPtr=0;
      dynaGram.tit3Sum=0;
      dynaGram.tit3Cnt=0;
      dynaGram.minPeriodOfDynagramCnt=0;  
      dynaGram.dataUpdatePWMCnt=0;
      dynaGram.outputVoltagePhase=0.0f;   
      dynaGram.outputVoltagePhaseSlip=0.0f;  
      dynaGram.compareVoltagePhase=0.0f; // Тут же после певого сигнала детектора - снять точку динамограммы      
      dynaGram.dynagramTimeOutCycles=((uint32_t)dynaGram.dynagramTimeOutSec)*((uint32_t)engine.freqPWM);          
      prevTick=HAL_GetTick();      
      dynaGram.state=1;    
      
      syncSpeed=engine.nomFreq*120.0f/(float)engine.polesNum;     
      dynaGram.motorSlipPercent=(syncSpeed-engine.nomSpeed)/syncSpeed;            
      if(engine.Inom>engine.Iidle)
      {
        dynaGram.motorSlipCoeff=-dynaGram.motorSlipPercent/(engine.Inom-engine.Iidle);      
        dynaGram.motorSlipConst=1.0f-dynaGram.motorSlipCoeff*engine.Iidle;        
        dynaGram.motorSlipCoeff=dynaGram.motorSlipCoeff/100.0f;
        dynaGram.motorSlipConst=dynaGram.motorSlipConst/100.0f;
      }else{
        dynaGram.motorSlipCoeff=0.0f;
        dynaGram.motorSlipConst=0.0f;       
      }       
    break;
    case 1:
      curTick=HAL_GetTick(); 
      if(curTick>prevTick) 
      {
	ms=curTick-prevTick;
      }else{
	ms=(0xFFFFFFFFL-prevTick)+(curTick+1L);
      }
      if(ms>=((uint32_t)dynaGram.dynagramUpdateSec*1000L))
      {
        dynaGram.state=2;
      }          
    break;
    case 4:            
      if(dynaGram.voltagePhaseRdy<2)
      {
        if(dynaGram.voltagePhaseRdy==1)
        {
          if(dynaGram.slipCompensationOn)dynaGram.voltagePhaseDPhi=dynaGram.outputVoltagePhaseSlip/200.0f; 
          else dynaGram.voltagePhaseDPhi=dynaGram.outputVoltagePhase/200.0f; 
            
          OMG=fabs(dynaGram.voltagePhaseDPhi-dPhi);
          if(dynaGram.voltagePhaseDPhi>0)OMG=100.0f*OMG/dynaGram.voltagePhaseDPhi;
          else OMG=100.0f;
          if(OMG<(float)dynaGram.slipPercent)
          {
            dynaGram.voltagePhaseRdy=2;            
          }else{                     
            dynaGram.error|=0x400;              
            dynaGram.voltagePhaseRdy=0;           
          }  
          dynaGram.state=0;
        }else{       
          dynaGram.voltagePhaseRdy=1;          
          if(dynaGram.slipCompensationOn)dPhi=dynaGram.outputVoltagePhaseSlip/200.0f; 
          else dPhi=dynaGram.outputVoltagePhase/200.0f;                    
          dynaGram.state=0;
        }
      }else{  
        maxActivePower=-32768;
        minActivePower=32767;        
        if(dynaGram.slipCompensationOn)dPhi=dynaGram.outputVoltagePhaseSlip/200.0f; 
        else dPhi=dynaGram.outputVoltagePhase/200.0f;  
        OMG=fabs(dynaGram.voltagePhaseDPhi-dPhi);
        if(dynaGram.voltagePhaseDPhi>0)OMG=100.0f*OMG/dynaGram.voltagePhaseDPhi;
        else OMG=100.0f;        
        if(OMG<(float)dynaGram.slipPercent)
        {
          if(dynaGram.rawDataPtr)
          {
            tempUINT16=dynaGram.rawDataPtr-1;
            for(i=0;i<dynaGram.rawDataPtr;i++)
            {
              dynaOutputData.Time[i]=(float)(dynaRawData[i].pwmSample)/(float)engine.freqPWM;                            // Вычисление очередного семпла в сек     
              dynaOutputData.Phase[i]=dynaRawData[i].phase/dynaGram.outputVoltagePhase;                                  
              dynaOutputData.slipPhase[i]=dynaRawData[i].phaseSlip/dynaGram.outputVoltagePhaseSlip;
              dynaOutputData.Watts[i]=dynaRawData[i].activePower;
              if(dynaOutputData.Watts[i]>maxActivePower)maxActivePower=dynaOutputData.Watts[i];
              if(dynaOutputData.Watts[i]<minActivePower)minActivePower=dynaOutputData.Watts[i];
              dynaOutputData.Force[i]=(float)dynaRawData[i].currentCode*dynaGram.tit3ToForceCoeff+dynaGram.tit3ToForceConst; // Показания с динамографа                        		
            }
            
            for(i=dynaGram.rawDataPtr;i<DYNA_POINTS;i++) // По какой-то причине второй сигнал оборота пришел раньше расчетного, для регулирования нельзя оставлять значения предыдущего скана
            {
              dynaOutputData.Time[i]=dynaOutputData.Time[tempUINT16];                    // Вычисление очередного семпла в сек     
              dynaOutputData.Phase[i]=dynaOutputData.Phase[tempUINT16];                  
              dynaOutputData.slipPhase[i]=dynaOutputData.slipPhase[tempUINT16];
              dynaOutputData.Watts[i]=dynaOutputData.Watts[tempUINT16];           
              dynaOutputData.Force[i]=dynaOutputData.Force[tempUINT16];                        		
            }
          }        
          dynaGram.state=5; // Для "разгрузки" процессора на другие задачи основного цикла 
        }else{                     
          dynaGram.error|=0x800;              
          dynaGram.voltagePhaseRdy=0;
          dynaGram.state=0;
        }
      }
    break; 	
    case 5:		
      maxLoad=0;
      minLoad=65535;      
      //maxShift=-32768;
      minShift=32767;
      minShiftSlip=32767;
      maxShiftLufkin=-32768;
      minShiftLufkin=32767;
      
      measurements.dynaGramTransCoeff=dynaGram.outputVoltagePhase;
      measurements.dynaGramTransCoeffSlip=dynaGram.outputVoltagePhaseSlip;
      
      for(i=0;i<DYNA_POINTS;i++)		
      {
        OMG=-dynaOutputData.Phase[i]+0.75f;// движение по часовой, устье слева        
        int32_t argument=(int32_t)(OMG*32768.0f); // Привожу к формату с фиксированной точкой                
        if(argument<0)
        {
          if(argument<-32768)argument+=65536;
          else argument+=32768;
        }else{
          if(argument>32767)argument-=32768;
        }			
        if((argument<0)||(argument>32767))argument=prevArgument; // Защита входных данных тригонометрических функций          
        prevArgument=argument;  
        Fa=-(float)dynaGram.l1-(float)dynaGram.r*(float)(arm_cos_q15((int16_t)argument))/32768.0f;
        Fb=(float)dynaGram.l2-(float)dynaGram.r*(float)(arm_sin_q15((int16_t)argument))/32768.0f;
        Z=((float)(dynaGram.l*dynaGram.l)-(float)(dynaGram.KK*dynaGram.KK)-Fa*Fa-Fb*Fb)/(2*(float)dynaGram.KK);			
        arm_sqrt_f32((Fb*Fb+Fa*Fa-Z*Z),&tempSqrt);
        y=(Fb-tempSqrt)/(Z+Fa);
        psi=2*atanf(y); // % угол поворота балансира
        dynaOutputData.Shift[i]=-(int16_t)((float)dynaGram.KK1*psi);     //ход штока с учетом наматывания на головку балансира радиуса KK1, мм               
        //if(dynaOutputData.Shift[i]>maxShift)maxShift=dynaOutputData.Shift[i];          
        if(dynaOutputData.Shift[i]<minShift)minShift=dynaOutputData.Shift[i];
      }
      
      for(i=0;i<DYNA_POINTS;i++)		
      {
        OMG=-dynaOutputData.slipPhase[i]+0.75f;// движение по часовой, устье слева        
        int32_t argument=(int32_t)(OMG*32768.0f); // Привожу к формату с фиксированной точкой                
        if(argument<0)
        {
          if(argument<-32768)argument+=65536;
          else argument+=32768;
        }else{
          if(argument>32767)argument-=32768;
        }			
        if((argument<0)||(argument>32767))argument=prevArgument; // Защита входных данных тригонометрических функций          
        prevArgument=argument;  
        Fa=-(float)dynaGram.l1-(float)dynaGram.r*(float)(arm_cos_q15((int16_t)argument))/32768.0f;
        Fb=(float)dynaGram.l2-(float)dynaGram.r*(float)(arm_sin_q15((int16_t)argument))/32768.0f;
        Z=((float)(dynaGram.l*dynaGram.l)-(float)(dynaGram.KK*dynaGram.KK)-Fa*Fa-Fb*Fb)/(2*(float)dynaGram.KK);			
        arm_sqrt_f32((Fb*Fb+Fa*Fa-Z*Z),&tempSqrt);
        y=(Fb-tempSqrt)/(Z+Fa);
        psi=2*atanf(y); // % угол поворота балансира
        dynaOutputData.slipShift[i]=-(int16_t)((float)dynaGram.KK1*psi);     //ход штока с учетом наматывания на головку балансира радиуса KK1, мм               
        //if(dynaOutputData.Shift[i]>maxShift)maxShift=dynaOutputData.Shift[i];          
        if(dynaOutputData.Shift[i]<minShiftSlip)minShiftSlip=dynaOutputData.slipShift[i];
      }
      
      if(dynaGram.algorithmOn==2)
      {
        minShift=0;        
        int16_t dLoad=(dynaGram.testDynagramLoadMax-dynaGram.testDynagramLoadMin)/50;
        int16_t dShift=(dynaGram.testDynagramShiftMax-dynaGram.testDynagramShiftMin)/50;        
        j=0; 
        for(i=0;i<50;i++)  
        {
          lufkinCardForce.pair[j].Position=dynaGram.testDynagramShiftMax;
          lufkinCardForce.pair[j].Load=dynaGram.testDynagramLoadMax-i*dLoad;  
          j++;
        }
        
        for(i=0;i<50;i++)
        {
          lufkinCardForce.pair[j].Position=dynaGram.testDynagramShiftMax-i*dShift;
          lufkinCardForce.pair[j].Load=dynaGram.testDynagramLoadMin;    
          j++;
        }
        for(i=0;i<50;i++)  
        {
          lufkinCardForce.pair[j].Position=dynaGram.testDynagramShiftMin;
          lufkinCardForce.pair[j].Load=dynaGram.testDynagramLoadMin+i*dLoad;  
          j++;
        }
        
        for(i=0;i<50;i++)
        {
          lufkinCardForce.pair[j].Position=dynaGram.testDynagramShiftMin+i*dShift;
          lufkinCardForce.pair[j].Load=dynaGram.testDynagramLoadMax;    
          j++;
        }
      }    
      
      for(i=0;i<DYNA_POINTS;i++)		
      {      
        if(dynaGram.slipCompensationOn)dynaOutputData.slipShift[i]-=minShiftSlip;
        else dynaOutputData.Shift[i]-=minShift;
        if(dynaGram.algorithmOn!=2)
        {
          if(dynaGram.slipCompensationOn)lufkinCardForce.pair[i].Position=dynaOutputData.slipShift[i];
          else lufkinCardForce.pair[i].Position=dynaOutputData.Shift[i];
          lufkinCardForce.pair[i].Load=(uint16_t)(dynaOutputData.Force[i]);
        }
        if(lufkinCardForce.pair[i].Position>maxShiftLufkin)maxShiftLufkin=lufkinCardForce.pair[i].Position;          
        if(lufkinCardForce.pair[i].Position<minShiftLufkin)minShiftLufkin=lufkinCardForce.pair[i].Position;       
        if(lufkinCardForce.pair[i].Load>maxLoad)maxLoad=lufkinCardForce.pair[i].Load;
        if(lufkinCardForce.pair[i].Load<minLoad)minLoad=lufkinCardForce.pair[i].Load;
      }
      
      
      lufkinCardForce.timeStamp=RTC_UnixTime.timeStamp;                       
      lufkinCardForce.numberOfPoints=200;           
      lufkinCardForce.maxLoad=maxLoad;      
      lufkinCardForce.minLoad=minLoad;
      lufkinCardForce.strokeLength=maxShiftLufkin-minShiftLufkin;
      lufkinCardForce.strokePeriod=(uint16_t)(dynaOutputData.Time[DYNA_POINTS-1]*100.0f);
      
      /*lufkinCardActivePower.timeStamp=RTC_UnixTime.timeStamp; 
      lufkinCardActivePower.numberOfPoints=200; 
      lufkinCardActivePower.maxActivePower=maxActivePower;
      lufkinCardActivePower.minActivePower=minActivePower;
      lufkinCardActivePower.strokeLength=maxShift-minShift;
      lufkinCardActivePower.strokePeriod=(uint16_t)(dynaOutputData.Time[DYNA_POINTS-1]*100.0f);
      */      
      if(dynaGram.algorithmOn)
      {        
        if(dynaGram.algorithmWorkLoadON>((float)lufkinCardForce.minLoad)) // Работа алгоритма по предотвращению зависания штанги
        {
          dynaGram.algorithmWorkLoadState=1;
        }else{
          if(dynaGram.algorithmWorkLoadOFF<((float)lufkinCardForce.minLoad))dynaGram.algorithmWorkLoadState=0;        
        }              
                       
        if(dynaGram.algorithmWorkLoadState)// Работа алгоритма по предотвращению зависания штанги
        {
          algorithmDF=command.currentFreqOrRPM-dynaGram.algorithmFreqChange;
          measurements.dynaGramAlgorithmDF=-dynaGram.algorithmFreqChange;
          dynaGram.error=0;
        }else{
          if(dynaGram.algorithmPumpRetryNum) // Включен режим работы по заполненности насоса
          {
            tempUINT16=(uint16_t)dynaGram.algorithmPumpShift;
            for(i=0;i<HALF_DYNA_POINTS;i++)		
            {
              if(lufkinCardForce.pair[i].Position<tempUINT16)break;  
            }    
            if((i==100)||(i==0))// Не нашли интересующую нас точку в рабочей области перемещения штанги            
            {
              dynaGram.error|=0x08; 
            }else{ 
              dynaGram.error=0;
              if((lufkinCardForce.pair[i].Position-tempUINT16)>(tempUINT16-lufkinCardForce.pair[i].Position))i-=1;  // Уточняем положение точки                                                                                      
              if(dynaGram.algorithmPumpForce>(float)lufkinCardForce.pair[i].Load) // Точка "внутри" динамограммы, повышать частоту                 
              {
                dynaGram.algorithmPumpRetryCntUP++;
                dynaGram.algorithmPumpRetryCntDOWN=0;
              }else{
                dynaGram.algorithmPumpRetryCntUP=0;
                dynaGram.algorithmPumpRetryCntDOWN++;              
              }
              if(dynaGram.algorithmPumpRetryCntUP>=dynaGram.algorithmPumpRetryNum)              
              {
                  algorithmDF=command.currentFreqOrRPM+dynaGram.algorithmFreqChange;
                  measurements.dynaGramAlgorithmDF=dynaGram.algorithmFreqChange;
                  dynaGram.algorithmPumpRetryCntUP=0;
              }else{
                if(dynaGram.algorithmPumpRetryCntDOWN>=dynaGram.algorithmPumpRetryNum)              
                {
                  algorithmDF=command.currentFreqOrRPM-dynaGram.algorithmFreqChange;   
                  measurements.dynaGramAlgorithmDF=-dynaGram.algorithmFreqChange;
                  dynaGram.algorithmPumpRetryCntDOWN=0;
                }              
              }             
            }            
          }else{ // Работает только алгоритм по предотвращению зависания штанги и увеличению числа качков
            algorithmDF=command.currentFreqOrRPM+dynaGram.algorithmFreqChange;
            measurements.dynaGramAlgorithmDF=dynaGram.algorithmFreqChange;
            dynaGram.error=0;
          }        
        }
        
        if(dynaGram.algorithmKp>0.000001f)
        { 
          if(dynaGram.algorithmPumpRetryNum==0)
          {
            measurements.dynaGramAlgorithmDF=dynaGram.algorithmKp*((float)lufkinCardForce.minLoad-dynaGram.algorithmWorkLoadON);
            algorithmDF=command.currentFreqOrRPM+measurements.dynaGramAlgorithmDF; 
          }
        }
        
        if(algorithmDF<dynaGram.algorithmFmin)
        {
          algorithmDF=dynaGram.algorithmFmin;
        }else{        
          if(algorithmDF>dynaGram.algorithmFmax)
          {
            algorithmDF=dynaGram.algorithmFmax;
          }
        }
        dynaGram.algorithmUpdateFreq=algorithmDF;
        dynaGram.updateFreq=1;        
        if(systemState.curMode==1) // Алгоритм изменения частоты в зависимости от динамограммы работает только в режиме ЧРЭП
        {
          if(context.freqSource[context.curContextNum]==0) // Алгоритм изменения частоты в зависимости от динамограммы работает только, когда исчтоник частоты-модбас
          {            
            dynaGram.algorithmState=2;      
          }
        }
      }      
      dynaGram.beeperOn=0;
      dynaGram.state=0;     
    break;
  }
}