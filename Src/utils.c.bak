void ShiftToRight(char *aString, int aCount)
{
    int i;
    
    for (i = strlen(aString) - 1; i >= 0; i--)
        aString[i + aCount] = aString[i];

};

void DoHTML(int aAnswerID, char *inBuf, unsigned int *aSize)
{
    int i;
    for (i = 0; i < 2048; i++)
        inBuf[i] = 0;
    
    switch (aAnswerID)
    {
    case PAGE_OK:
        sprintf (inBuf , "%s", HTMLString);
        break;
    case PAGE_MAIN:
        sprintf(inBuf, "%s", HTMLString);
        break;
    case PAGE_MAIN_MENU:
        sprintf(inBuf, "%s", HTMLString);
        break;
    case PAGE_MENU:
        sprintf(inBuf, "%s", HTMLString);
        break;
    case PAGE_MENU_1:
        sprintf(inBuf, "%s", HTMLString);
        break;        
    case PAGE_MENU_ARHIVE:
        sprintf(inBuf, "%s", HTMLString);
        break;           
    case PAGE_ERROR:
        sprintf (inBuf , "%s", HTMLString);
        break;
    case PAGE_ERROR_500:
        sprintf (inBuf , "%s", HTMLString);
        break;
        
    default:
        if (strlen(HTMLString) < MAX_SIZE_ONE_HTML_PACKET)
          sprintf(inBuf, "%s", HTMLString);
        else
        {
          for (i = 0; i < MAX_SIZE_ONE_HTML_PACKET; i++)
            inBuf[i] = HTMLString[i];
        }
        break;
    };
    
    *aSize = strlen(inBuf);

};

void convert_unix_2_date( unsigned long int time_sec)
{
   unsigned char dobavka;
   
   u_2_sec = time_sec%60;
   time_sec = time_sec/60;
   u_2_min = time_sec%60;
   time_sec = time_sec/60;  // остались часы
   u_2_hor = time_sec%24; 
   time_sec = time_sec/24;  // это дни начиная с 2000 года
   u_2_year = (time_sec/1461)*4;
   time_sec = time_sec%1461;
   time_sec++;
   if ( time_sec <=366) 
   {
     dobavka = 1;
     goto visok;
   }
   else 
     dobavka = 0;
   
   u_2_year = u_2_year + 1;
   time_sec = time_sec - 366;
   u_2_year = u_2_year + (time_sec/365);
   
   if ( (time_sec%365) == 0) 
   { 
     u_2_year = u_2_year - 1; 
     time_sec = 365; 
   }
   else 
     time_sec = time_sec%365;
   
visok:   
   
   if (time_sec <= 31)           
   {
     u_2_month = 1;
     u_2_date = time_sec;
     return;
   }
   time_sec = time_sec - 31;
   
   if (time_sec <= (28 + dobavka)) 
   {
     u_2_month = 2;
     u_2_date = time_sec;
     return;
   }
   time_sec = time_sec - (28 + dobavka);
   
   if (time_sec <= 31)          
   {
     u_2_month = 3;
     u_2_date = time_sec;
      return;
   }
   time_sec = time_sec - 31;
    
   if (time_sec <= 30)          
   {
     u_2_month = 4;
     u_2_date = time_sec;
     return;
   }
   time_sec = time_sec - 30;
    
   if (time_sec <= 31)          
   {
     u_2_month=5;
     u_2_date = time_sec;
     return;
   }
   time_sec=time_sec-31;
    
   if (time_sec <= 30)          
   {
     u_2_month = 6;
     u_2_date = time_sec;
     return;
   }
   time_sec = time_sec - 30;
   
   if (time_sec <= 31)          
   { 
     u_2_month = 7;
     u_2_date = time_sec;
     return;
   }
   time_sec=time_sec - 31;
     
   if (time_sec <= 31)          
   {
     u_2_month = 8;
     u_2_date = time_sec;
     return;
   }
   time_sec=time_sec-31;
     
   if (time_sec <= 30)           
   {
     u_2_month = 9;
     u_2_date = time_sec;
     return;
   }
   time_sec = time_sec - 30;
     
     
   if (time_sec <= 31)          
   {
     u_2_month = 10;
     u_2_date = time_sec;
     return;
   }
   time_sec = time_sec - 31;
    
   if (time_sec <= 30)            
   { 
     u_2_month = 11;
     u_2_date = time_sec;
     return;
   }
   time_sec=time_sec-30;
   
   if (time_sec <= 31)           
   {
     u_2_month = 12;
     u_2_date = time_sec;
     return;
   }
     
}

