// возвращает адрес следующего элемента, после копирования
unsigned char *copy_P(char *dest,const char *src)
        //unsigned char *copy_P(unsigned char *dest,char const *src)
{
    //for (ii=0;ii<sizeof(webif_200_header)-1;ii++) *dest++=*src++;
    while(*src) *dest++=*src++;
    *dest = 0;
    return(dest);
}

int CurrPos; // Текущаая позиция для функции Pos в CheskWordInString
unsigned int LengthInBuf;
// функция возвращает позицию первого вхождение подстроки substr в строке str начиная с позиции idx
// возвращает -1 если не найдено
int Pos(char *substr, char *str, int idx)
{
    int i, j, result = -1;
    enum bool flOK;
    int len_substr = strlen(substr); //длина подстроки без 0 символа
    int len_str = strlen(str); //длина строки
    
    for (i = idx; i <= len_str - len_substr; i++)
    {
        flOK = true;
        for (j = 0; j < len_substr; j++)
        {
            if (substr[j] != str[i + j])
            {
                flOK = false;
                break;
            }
        }
        if (flOK)
        {
            result = i;
            break;
        }
    }
    return result;
}

float ExtractFloat(char *aString, int aIndex, int aSize)
{
    int i, IntPart;
    long int koef;
    float result;
    
    koef = 1;
    result = 0;
    IntPart = 0;
    
    if (aIndex < 0)
    {
        for (i = aSize - 1; i >= 0; i--)
        {
            result = result + (aString[i] - 0x30) * koef;
            koef = koef * 10;
        }
        return result;      
    }
    
    for (i = aIndex - 1; i >=0; i--)
    {
        IntPart = IntPart + (aString[i] - 0x30) * koef;
        koef = koef * 10;
    };

    koef = 1;

    for (i = aSize - 1; i > aIndex; i--)
    {
        result = result + (aString[i] - 0x30) * koef;
        koef = koef * 10;
    };

    result = IntPart + result/koef;
    return result;
}

float StrToFloat(char *aString)
{
    int idx;
    int sz;
    float result;

    sz = strlen(aString);

    if (sz < 1)
        return 0;
    idx = Pos(",", aString, 0);
    if (idx < 0)
    {
        idx = Pos(".", aString, 0);
        if (idx < 0)
        {
            //целое значение
            result = ExtractFloat(aString, idx, sz);
        }
        else
        {
            //разделитель точка
            result = ExtractFloat(aString, idx, sz);
        }
    }
    else
    {
        //разделитель запятая
        result = ExtractFloat(aString, idx, sz);
    }
    return result;
}

char FloatToStr(float aValue, char *aString)
{
    int i, j;
    long int i1;
    float f;
    unsigned long int i2;
    int sz;

    if (isnan(aValue))
    {
        return 0;
    } 
    else 
      if (isinf(aValue)) 
      {
         return 0;
      };
      
    for (i = 0; i < 10; i++)
        strFloat2[i] = 0;

    i1 = aValue;
    f = aValue - i1;
    i2 = 1;
    for (i = 0; i < 6; i++)
    {
        i2 = f * 10;
        if (f * 10 - i2 == 0)
            break;
        f = f * 10;
    };

    sprintf(strFloat1,"%lu", i2);
    sz = strlen(strFloat1);
    sz = i - sz;
    if (sz > 0)
    {
        for (j = 0; j < sz; j++)
            strFloat2[j] = 0x30;
        sprintf(aString,"%ld.%s%lu", i1, strFloat2, i2);
    }
    else
        sprintf(aString,"%ld.%lu", i1, i2);
    
    return 1;
};


enum bool CheskWordInString(char *substr, char *str)
{
    int i;

    i = Pos(substr, str, CurrPos);
    
    if (i >= 0)
    {
        CurrPos = i;
        return  true;
    }
    else
        return false;
};

int StrToInt(char *str)
{
    int i, n, result, k, d;

    result = 0;
    k = 1;
    n = strlen(str);

    if (n < 1)
        return -1;

    for (i = n - 1; i >= 0; i--)
    {
        if (str[i] == '?')
          continue;
        d = str[i] - 0x30;
        if ((d >= 0) && (d <= 9))
        {
            result = result + (str[i] - 0x30) * k;
            k = k * 10;
        }
        else
            return -1;
    }

    return result;
    
}

int GetAnswerID(char *str)
{
    int i, b, e, result;
    

    for (i = 0; i < 20; i++)
        sAnswerID[i] = 0;
    
    b = Pos("GET /", str, CurrPos) + 5;
    e = Pos(" HTTP/", str, CurrPos);
    
    if (b == e)
        return PAGE_MAIN;
    
    for (i = 0; i < e - b; i++)
        sAnswerID[i] = str[i + b];

    if (strcmp(sAnswerID, "mainmenu.html") == 0)
        return PAGE_MAIN_MENU;
    
    if (strcmp(sAnswerID, "menu.html") == 0)
        return PAGE_MENU;

    if (strcmp(sAnswerID, "menu1.html") == 0)
        return PAGE_MENU_1;
    
    if (strcmp(sAnswerID, "menuarhive.html") == 0)
        return PAGE_MENU_ARHIVE;
    
    if (strcmp(sAnswerID, "favicon.ico") == 0)
        return PAGE_ERROR;
    
    result = StrToInt(sAnswerID); //atoi(sAnswerID);
    
    if (( result > MAX_ARRSECTION - 1) || (result < 0))
        return PAGE_ERROR;
    
    PrevID = result;
    return result;
}

// Возвращает номер канала найденный после IPD+
int FindChanel(char *str)
{
    int i, j;
    enum bool flOK = true;
    
    for (i = 0; i < 5; i++)
        sFindChanel[i] = 0;
    
    i = Pos("+IPD,", str, CurrPos) + 5; // 4 - длина IPD+
    j = 0;
    
    while  (str[i] != ',')
    {
        sFindChanel[j] = str[i];
        j++;
        i++;
        if (i > strlen(str))
        {
            flOK = false;
            break;

        };
    };
    
    if (flOK)
        return  atoi(sFindChanel);
    else
        return -1;
};

void DeleteHtmlItem(int aIndex)
{
    int i;
    if (CountItemInHtmlList == 0)
        return;
    if (aIndex > MAX_HTML_ITEM - 1)
        return;
    for (i = aIndex; i <= MAX_HTML_ITEM - 2; i++)
        htmlList[i] = htmlList[i + 1];
    CountItemInHtmlList--;
}

void DeleteItemOfChanel(char * str)
{
    int i, j, chnl;
    

    if (CountItemInHtmlList == 0)
        return;

    j = Pos(",CLOSED", str, 0);

    //memcpy(sDeleteItemOfChanel, str + (j - 1), 1);
    //chnl = atoi(sDeleteItemOfChanel);
    chnl = str[j - 1] - 0x30;
    i = 0;
    while (true)
    {
        if (htmlList[i].Chanel == chnl)
            DeleteHtmlItem(i);
        else
            i++;

        if (i >= CountItemInHtmlList)
            break;
    };
};

void AddHtmlItemInList(ThtmlItem aItem)
{
    if (CountItemInHtmlList >= MAX_HTML_ITEM - 1)
        return;
    CountItemInHtmlList++;
    htmlList[CountItemInHtmlList - 1] = aItem;
};

void ExtractDataFromString(char *inBuf, unsigned int aSize)
{
    int i, idx1, idx2;
    
    while (true)
    {
        idx1 = Pos(NAME_POST, inBuf, CurrPos);
        if (idx1 < 0)
            break;
        //Очищаем массивы для номера параметра и значения
        for (i = 0; i < 10; i++)
        {
            sID[i] = 0;
            ValStr[i] = 0;
        };
        CurrPos = idx1;
        idx1 = idx1 + strlen(NAME_POST); // позиция первой цифры в конструкции rinatXXX
        idx2 = Pos("=", inBuf, CurrPos);
        // Получаем номер параметра
        for(i = idx1; i < idx2; i++)
            sID[i - idx1] = inBuf[i];

        idx1 = idx2 + 1; // в idx1 позиция за символом '='
        idx2 = Pos("&", inBuf, CurrPos);

        if (idx2 < 0)
            idx2 = aSize;
        // Получаем значение параметра
        for(i = idx1; i < idx2; i++)
            ValStr[i - idx1] = inBuf[i];
        //преобразуем индекс в число
        i = atoi(sID);
        CurrPos = idx2;
        // Получаем сруктуру параметра по индексу
        PItem = GetParam(&ParamItem[i].Name[0]);
        WriteDataToMemory(ValStr);
        
        if (idx2 == aSize)
            break;
    };
};
// inBuf - входной\выходной буфер. *aSize - размер выходного пакета
char CreateHtmlItem(char *inBuf, unsigned int *aSize, unsigned int aSizeIn)
{
    int id, i, sz;
    int chnl;
    ThtmlItem htmlItem;
    char result;
    
    result = NOT_WRITE_PORT;

    if (aSizeIn > 0)
    {

        CurrPos = 0;
        LengthInBuf = aSizeIn;
        
        if (CountItemInHtmlList > 0)
        {
            switch (htmlList[0].Step)
            {
            case STEP_WAIT_SEND_OK:
                if (CheskWordInString("SEND OK", inBuf))
                {
                    sz = strlen(HTMLString);
                    if ( sz > MAX_SIZE_ONE_HTML_PACKET)
                    {
                      StepCount++;
                      for (i = 0; i < sz - MAX_SIZE_ONE_HTML_PACKET; i++)
                        HTMLString[i] = HTMLString[i + MAX_SIZE_ONE_HTML_PACKET];
                      sz = sz - MAX_SIZE_ONE_HTML_PACKET; 
                      for (i = sz; i < MAX_SIZE_HTML_PACKET; i++)
                        HTMLString[i] = 0;
                      
                      if (DoSendAT(htmlList[0].Chanel, htmlList[0].ID, inBuf, aSize) == 0)
                          htmlList[0].ID = PAGE_ERROR_500;
                      htmlList[0].Step = STEP_WAIT_OK;
                      Flag_Wait_OK = 1;
                      CountSecWaitOK = 0;
                      result = WRITE_PORT;
                      break;                      
                    }
                    else
                    {
                    DeleteHtmlItem(0);
                    
                    break;
                    }
                }
                else
                    CountItemInHtmlList = 0;
                break;
           case STEP_WAIT_OK:
                if (CheskWordInString("OK\r\n>", inBuf))
                {
                    Flag_Wait_OK = 0;
                    htmlList[0].Step = STEP_HTML;
                    DoHTML(htmlList[0].ID, inBuf, aSize);
                    htmlList[0].Step = STEP_WAIT_SEND_OK;
                    result = WRITE_PORT;
                    return result;
                }
                else
                    CountItemInHtmlList = 0;
                break;
            };
        };
        
        //CurrPos = 0;
        //if (CheskWordInString("CLOSED", inBuf))
        //    DeleteItemOfChanel(inBuf);
        CurrPos = 0;


        while (true)
        {
            if (CheskWordInString("+IPD,", inBuf))
            {
                
                chnl = FindChanel(inBuf);

                if (CheskWordInString("GET /", inBuf))
                {
                    id = GetAnswerID(inBuf);
                    ColorHtmlText = 0;
                    if (id >=0)
                    {
                        htmlItem.Chanel = chnl;
                        htmlItem.ID = id;
                        htmlItem.Step = STEP_CIPSEND;
                        AddHtmlItemInList(htmlItem);

                    };
                }
                else
                {

                    if (CheskWordInString("POST /", inBuf))
                    {
                        id = PrevID;
                        ColorHtmlText = 1;
                        ExtractDataFromString(inBuf, aSizeIn); //Надо дописать
                        if (id >= 0)
                        {
                            htmlItem.Chanel = chnl;
                            htmlItem.ID = id;
                            htmlItem.Step = STEP_CIPSEND;
                            AddHtmlItemInList(htmlItem);

                        };

                    };
                };
            }
            else
                break;

        };

        if (CountItemInHtmlList == 0)
            return result;

        switch (htmlList[0].Step)
        {
        case STEP_CIPSEND:
            ClearHTMLString();
            StepCount = 0;
            if (DoSendAT(htmlList[0].Chanel, htmlList[0].ID, inBuf, aSize) == 0)
              htmlList[0].ID = PAGE_ERROR_500;
            htmlList[0].Step = STEP_WAIT_OK;
            Flag_Wait_OK = 1;
            CountSecWaitOK = 0;
            result = WRITE_PORT;
            break;
        case STEP_HTML:
            
	    DoHTML(htmlList[0].ID, inBuf, aSize);
            htmlList[0].Step = STEP_WAIT_SEND_OK;
            result = WRITE_PORT;
            break;
        };
        
    };
    return result;
};

void CopyCIPSEND(int aData1, int aData2, char *inBuf)
{
  copy_P(inBuf, AT_CIPSEND_1);
  sprintf(inBuf + strlen(inBuf), "%d", aData1);
  copy_P(inBuf + strlen(inBuf), AT_CIPSEND_2);
  sprintf(inBuf + strlen(inBuf), "%d", aData2);
  copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
}

char  DoSendAT(int aID, int aAnswerID, char *inBuf, unsigned int *aSize)
{
    char result = 1;
    int i;
    int sz;
    
    //ClearHTMLString();
    
    switch (aAnswerID)
    {
    case PAGE_OK:
        copy_P(HTMLString, AnswerOK);
        //sprintf(inBuf, "AT+CIPSEND=%d,%d\r\n", aID, strlen(HTMLString));
        CopyCIPSEND(aID, strlen(HTMLString), inBuf);
        break;
    case PAGE_MAIN:
        copy_P(inBuf, AnswerMain);
        sz = strlen(inBuf); // размер AnswerMain
        
        copy_P(inBuf, AnswerHead);
        sprintf(HTMLString, "%s%d", inBuf, sz); // Заголовок с размером AnswerMain
        copy_P(HTMLString + strlen(HTMLString), AT_CIPSEND_3);
        copy_P(HTMLString + strlen(HTMLString), AT_CIPSEND_3);
        copy_P(inBuf, AnswerMain);
        sz = strlen(inBuf) + strlen(HTMLString); // Размер пакета с заголовком
        //*** Создаем пакет с заголовком в HTMLString
        
        strcat (HTMLString, inBuf);
        
        //sprintf(inBuf, "AT+CIPSEND=%d,%d\r\n", aID, sz);
        CopyCIPSEND(aID, sz, inBuf);
        break;
    case PAGE_MAIN_MENU:
        copy_P(inBuf, AnswerMainMenu);
        sz = strlen(inBuf); // размер AnswerMain
        
        copy_P(inBuf, AnswerHead);
        sprintf(HTMLString, "%s%d", inBuf, sz); // Заголовок с размером AnswerMain
        copy_P(HTMLString + strlen(HTMLString), AT_CIPSEND_3);
        copy_P(HTMLString + strlen(HTMLString), AT_CIPSEND_3);
        copy_P(inBuf, AnswerMainMenu);
        sz = strlen(inBuf) + strlen(HTMLString); // Размер пакета с заголовком
        //*** Создаем пакет с заголовком в HTMLString
        
        strcat (HTMLString, inBuf);
        
        //sprintf(inBuf, "AT+CIPSEND=%d,%d\r\n", aID, sz);
        CopyCIPSEND(aID, sz, inBuf);
        break;        
    case PAGE_MENU:
        CurrentMenu = 0;
        StepCount = 0;
        CreateMenuForBrowser();
        sz = strlen(HTMLString);
        copy_P(inBuf, AnswerHead);
        sprintf(inBuf + strlen(inBuf), "%d", sz);
        copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
        copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
        sz = strlen(inBuf) + strlen(HTMLString);
        strcat(inBuf, HTMLString);
        sprintf(HTMLString, "%s", inBuf);
                
        //sprintf(inBuf, "AT+CIPSEND=%d,%d\r\n", aID, sz);
        CopyCIPSEND(aID, sz, inBuf);
        break;
    case PAGE_MENU_1:
        CurrentMenu = 1;
        StepCount = 0;
        CreateMenuForBrowser_1();
        sz = strlen(HTMLString);
        copy_P(inBuf, AnswerHead);
        sprintf(inBuf + strlen(inBuf), "%d", sz);
        copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
        copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
        sz = strlen(inBuf) + strlen(HTMLString);
        strcat(inBuf, HTMLString);
        sprintf(HTMLString, "%s", inBuf);
                
        //sprintf(inBuf, "AT+CIPSEND=%d,%d\r\n", aID, sz);
        CopyCIPSEND(aID, sz, inBuf);
        break;    
    case PAGE_MENU_ARHIVE:
        CurrentMenu = 2;
        StepCount = 0;
        CreateMenuForBrowser_2();
        sz = strlen(HTMLString);
        copy_P(inBuf, AnswerHead);
        sprintf(inBuf + strlen(inBuf), "%d", sz);
        copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
        copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
        sz = strlen(inBuf) + strlen(HTMLString);
        strcat(inBuf, HTMLString);
        sprintf(HTMLString, "%s", inBuf);
                
        //sprintf(inBuf, "AT+CIPSEND=%d,%d\r\n", aID, sz);
        CopyCIPSEND(aID, sz, inBuf);
        break;        
        
    case PAGE_ERROR:
        copy_P(HTMLString, AnswerError);
        
        //sprintf(inBuf, "AT+CIPSEND=%d,%d\r\n", aID, strlen(HTMLString));
        CopyCIPSEND(aID, strlen(HTMLString), inBuf);
        break;
    default:
        if (StepCount == 0)
        {
          switch (CurrentMenu)
          {
          case 0: 
            CreatPageForBrowser(aAnswerID);
            break;
          case 1: 
            CreatPageForBrowser_1(aAnswerID);
            break;
          case 2: 
            CreatPageForBrowser_2(aAnswerID);
            break;
          default:
            return 0;
          }
        
          sz = strlen(HTMLString);
          copy_P(inBuf, AnswerHead);
          sprintf(inBuf + strlen(inBuf), "%d", sz); 
          copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
          copy_P(inBuf + strlen(inBuf), AT_CIPSEND_3);
          
          sz = strlen(inBuf) + strlen(HTMLString);
          if (sz < 2048)
          {  
          strcat(inBuf, HTMLString);
          sprintf(HTMLString, "%s", inBuf);

          CopyCIPSEND(aID, sz, inBuf);
          }
          else
          {
            for (i = strlen(HTMLString) - 1; i >= 0; i--)
              HTMLString[strlen(inBuf) + i] = HTMLString[i];
            for (i = 0; i < strlen(inBuf); i++)
              HTMLString[i] = inBuf[i];
            CopyCIPSEND(aID, MAX_SIZE_ONE_HTML_PACKET, inBuf);
          }
        }
        else
        {
          sz = strlen(HTMLString);
          if (sz < 2048)
            CopyCIPSEND(aID, sz, inBuf);
          else
            CopyCIPSEND(aID, MAX_SIZE_ONE_HTML_PACKET, inBuf);
        }
    };
    
    
    //sprintf(inBuf,"%s", sDoSendAT);
    *aSize = strlen(inBuf);
    return result;
};

