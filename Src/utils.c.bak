char GetCountWord(void)
{
    switch (PItem.TypeValue)
    {
    case INT: return 1;
    case UINT: return 1;
    case DINT: return 2;
    case UDINT: return 2;
    case REAL: return 2;
    case STR: return PItem.BitFieldCount/2;
    default: return 0;
    };
};

unsigned int GetMaskInt(char aBitFieldStart, char aBitFieldCount)
{
    int i;
    unsigned int result, d;

    result = 0;
    for (i = aBitFieldStart; i < aBitFieldStart + aBitFieldCount; i++)
    {
        d = 1 << i;
        result = result + d;
    };
    return result;
};

unsigned long int GetMaskWord(char aBitFieldStart, char aBitFieldCount)
{
    int i;
    unsigned long int result, d;
    result = 0;
    for (i = aBitFieldStart; i < aBitFieldStart + aBitFieldCount; i++)
    {
        d = 1 << i;
        result = result + d;
    };
    return result;
};

char WriteDataToMemory(char *aValStr)
{
    char sz;
    int16_t val_int;
    uint32_t mask32, val_long;
    uint16_t mask16;
    
    
    // sz -количество слов которое надо прочитать, если 0 то ничего не делать
    sz = GetCountWord();
    if (sz == 0)
        return 0;
    if (PItem.isBitField)
    {
        if (read_modbus(READ_DATA, PItem.Adres, sz, ValData) == 0)
            return 0;
    }
    

    switch (PItem.TypeValue)
    {
    case INT: 
        val_int = atoi(aValStr);
        if (PItem.isBitField)
        {
            mask16 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            ValData[0] = ValData[0] & (~mask16);
            val_int = val_int << PItem.BitFieldStart;
            ValData[0] = ValData[0] | val_int;

        }
        else
            ValData[0] = val_int;

        break;
    case UINT: 
        val_int = atoi(aValStr);
        if (PItem.isBitField)
        {
            mask16 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            ValData[0] = ValData[0] & (~mask16);
            val_int = val_int << PItem.BitFieldStart;
            ValData[0] = ValData[0] | val_int;

        }
        else
            ValData[0] = val_int;
        
        break;
    case DINT: 

        val_long = atol(aValStr);
        if (PItem.isBitField)
        {
            val_Integer.Word[0] = ValData[0];
            val_Integer.Word[1] = ValData[1];          
            mask32 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            val_Integer.Value = val_Integer.Value & (~mask32);
            val_long = val_long << PItem.BitFieldStart;
            val_Integer.Value = val_DWord.Value | val_long;
            ValData[0] = val_Integer.Word[0];
            ValData[1] = val_Integer.Word[1];
        }
        else
        {
            val_Integer.Value = val_long;
            ValData[0] = val_Integer.Word[0];
            ValData[1] = val_Integer.Word[1];

        };
        break;
    case UDINT:
        
        val_long = atol(aValStr);
        if (PItem.isBitField)
        {
            val_DWord.Word[0] = ValData[0];
            val_DWord.Word[1] = ValData[1];
            mask32 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            val_DWord.Value = val_Integer.Value & (~mask32);
            val_long = val_long << PItem.BitFieldStart;
            val_DWord.Value = val_DWord.Value | val_long;
            ValData[0] = val_DWord.Word[0];
            ValData[1] = val_DWord.Word[1];
        }
        else
        {
            val_DWord.Value = val_long;
            ValData[0] = val_DWord.Word[0];
            ValData[1] = val_DWord.Word[1];

        };

        break;
    case REAL:
        val_Float.Value = atof(aValStr); //StrToFloat(aValStr); 
        ValData[0] = val_Float.Word[0];
        ValData[1] = val_Float.Word[1];
        break;

  default: return 0;
  };


    if (read_modbus(WRITE_DATA, PItem.Adres, sz, ValData) == 0)
        return 0;
    return 1;
};

char ReadDataFromMemory(char *aValStr)
{
    char sz;
    int i;
    int16_t val_int; 
    uint32_t mask32;
    uint16_t mask16;
    
    // sz -количество слов которое надо прочитать, если 0 то ничего не делать
    sz = GetCountWord();
    if (sz == 0)
        return 0;

    if (read_modbus(READ_DATA, PItem.Adres, sz, ValData) == 0)
        return 0;
    
  
    switch (PItem.TypeValue)
    {
    case INT: 
        val_int = (int16_t)ValData[0];
        if (PItem.isBitField)
        {
            mask16 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            val_int = val_int & mask16;
            val_int = val_int >> PItem.BitFieldStart;
            ValData[0] = val_int;

        };
        sprintf(aValStr, "%d", val_int);

        break;
    case UINT: 
        if (PItem.isBitField)
        {
            mask16 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            ValData[0] = ValData[0] & mask16;
            ValData[0] = ValData[0] >> PItem.BitFieldStart;

        };
        sprintf(aValStr, "%u", ValData[0]);
        break;
    case DINT: 
        val_Integer.Word[0] = ValData[0];
        val_Integer.Word[1] = ValData[1];
        if (PItem.isBitField)
        {
            mask32 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            val_Integer.Value = val_Integer.Value & mask32;
            val_Integer.Value = val_Integer.Value >> PItem.BitFieldStart;
        };
        sprintf(aValStr, "%ld", val_Integer.Value);
        break;
    case UDINT:
        val_DWord.Word[0] = ValData[0];
        val_DWord.Word[1] = ValData[1];
        if (PItem.isBitField)
        {
            mask32 = GetMaskInt(PItem.BitFieldStart, PItem.BitFieldCount);
            val_DWord.Value = val_DWord.Value & mask32;
            val_DWord.Value = val_DWord.Value >> PItem.BitFieldStart;
        };
        sprintf(aValStr, "%lu", val_DWord.Value);

        break;
    case REAL:
        val_Float.Word[0] = ValData[0];
        val_Float.Word[1] = ValData[1];
        //if (FloatToStr(val_Float.Value, aValStr) == 0)
        //  aValStr[0] = 0;
        sprintf(aValStr, "%f", (double)val_Float.Value);
        break;
    case STR:
        for (i = 0; i < MAX_COUNT_WORD; i++)
        {
          aValStr[i * 2 + 1] = ValData[i] & 0xff;
          aValStr[i * 2] = ValData[i] >> 8;
        }
        break;
  default: return 0;
  };

 
    return 1;
};

int GetLastIndexArhive(void)
{
  if (read_modbus(READ_DATA, ADRES_ARHIVE_INDEX, 1, ValData) == 0)
        return -1; 
  return ValData[0];
};

char ReadDataFromArhive(char *aValStr, int aDirect)
{
    
    if (read_modbus(READ_DATA, ADRES_ARHIVE + CurrentArhiveIndex * 7, 7, ValData) == 0)
        return 0;
    
   
    val_DWord.Word[0] = ValData[0];
    val_DWord.Word[1] = ValData[1];
    convert_unix_2_date(val_DWord.Value); 
    
    aValStr[0] = (u_2_date/10) + 0x30;
    aValStr[1] = (u_2_date%10) + 0x30;
    aValStr[2] = '.';
    aValStr[3] = (u_2_month/10) + 0x30;
    aValStr[4] = (u_2_month%10) + 0x30;
    aValStr[5] = '.';
    aValStr[6] = '2';
    aValStr[7] = '0';
    aValStr[8] = (u_2_year/10) + 0x30;
    aValStr[9] = (u_2_year%10) + 0x30;
    aValStr[10] = ' ';        
    aValStr[11] = (u_2_hor/10) + 0x30;
    aValStr[12] = (u_2_hor%10) + 0x30;
    aValStr[13] = ':';
    aValStr[14] = (u_2_min/10) + 0x30;
    aValStr[15] = (u_2_min%10) + 0x30;
    aValStr[16] = ':';
    aValStr[17] = (u_2_sec/10) + 0x30; 
    aValStr[18] = (u_2_sec%10) + 0x30; 
    aValStr[19] = ' ';
    aValStr[20] = 0;
    
    //sprintf(aValStr + strlen(aValStr), "%u", ValData[5]);
    
    switch (aDirect)
    {
    case 0:// Предыдущий
    case 2: // Текущий    
      if (CurrentArhiveIndex == 0) 
        CurrentArhiveIndex = MAX_ARHIVE_STACK - 1;
      else
        CurrentArhiveIndex--;
      break;
    case 1:// Следующий
      if (CurrentArhiveIndex == MAX_ARHIVE_STACK - 1)
        CurrentArhiveIndex = 0;
      else
        CurrentArhiveIndex++;      
      break;
    default:
      return 0;
    }

    return 1;
};

void ClearHTMLString(void)
{
  int i;
  for (i = 0; i < MAX_SIZE_HTML_PACKET; i++)
    HTMLString[i] = 0;
}

// страница с параметрами для браузера
char CreatPageForBrowser(int aIndex)
{
    int i;
    
    ClearHTMLString();

    
    if (ColorHtmlText == 0)
      copy_P(HTMLString, html_text_black); //sprintf (HTMLString , "%s", "<html>\r\n <body text = \"#000000\">\r\n");
    else
      copy_P(HTMLString, html_text_blue); //sprintf (HTMLString , "%s", "<html>\r\n <body text = \"#0000ff\">\r\n");
    
    //sprintf (HTMLString + strlen(HTMLString) - 1, "%s","<form action='/' method='POST'>\r\n");
    //strcat(HTMLString, "<br>\r\n");
    copy_P(HTMLString + strlen(HTMLString), html_method);
    
    for (i = 0; i < SECTION_SIZE; i++)
        SectionName[i] = 0;
    copy_P(SectionName, ArrSection[aIndex]);

    //sprintf (HTMLString + strlen(HTMLString) - 1, "<font color=\"#ff0000\">Раздел: %s</font>\r\n", SectionName);
    //strcat(HTMLString, "<br>\r\n");
    //strcat(HTMLString, "<font size=\"-2\">\r\n");
    copy_P(HTMLString + strlen(HTMLString), html_font_color_1);
    sprintf (HTMLString + strlen(HTMLString), "%s", SectionName);
    copy_P(HTMLString + strlen(HTMLString), html_font_color_2);
    
    for (i = 0; i <= MAX_PARAM_ITEM - 1; i++)
    {
        
        PItem = GetParam(&ParamItem[i].Name[0]);

        if (PItem.SectionIndex == aIndex)
        {
            CurrentMenu = 0;
            ReadDataFromMemory(ValStr);
            
            sprintf(HTMLString + strlen(HTMLString), "%s", PItem.Name);
            //sprintf(HTMLString + strlen(HTMLString) - 1, "\r\n<input type='text' name='%s%d' size='10' value='%s'>\r\n", NAME_POST, i, ValStr);
            //strcat(HTMLString, "<br>\r\n");
            copy_P(HTMLString + strlen(HTMLString), html_input_type_1);
            sprintf(HTMLString + strlen(HTMLString), "%s%d", NAME_POST, i);
            copy_P(HTMLString + strlen(HTMLString), html_input_type_2);
            sprintf(HTMLString + strlen(HTMLString), "%s", ValStr);
            copy_P(HTMLString + strlen(HTMLString), html_input_type_3);
        };
    };
    //strcat(HTMLString, "</font>\r\n");
    //strcat(HTMLString, "<input type='submit' value='OK'>\r\n</form>\r\n");
    //strcat(HTMLString, "</body>\r\n </html>\r\n");
    copy_P(HTMLString + strlen(HTMLString), html_end);
    
    return 1;
};

// страница с параметрами для браузера чтение
char CreatPageForBrowser_1(int aIndex)
{
    int i;
    
    ClearHTMLString();

    
    if (ColorHtmlText == 0)
      copy_P(HTMLString, html_text_black);
    else
      copy_P(HTMLString, html_text_blue);

    copy_P(HTMLString + strlen(HTMLString), html_method_get_1);
    sprintf(HTMLString + strlen(HTMLString), "%d", aIndex);
    copy_P(HTMLString + strlen(HTMLString), html_method_get_2);
    
    for (i = 0; i < SECTION_SIZE; i++)
        SectionName[i] = 0;
    copy_P(SectionName, ArrSection_1[aIndex]);

    copy_P(HTMLString + strlen(HTMLString), html_font_color_1);
    sprintf(HTMLString + strlen(HTMLString), "%s", SectionName);
    copy_P(HTMLString + strlen(HTMLString), html_font_color_2);
    
    for (i = 0; i <= MAX_PARAM_ITEM_1 - 1; i++)
    {
        
        PItem = GetParam(&ParamItem_1[i].Name[0]);

        if (PItem.SectionIndex == aIndex)
        {
            CurrentMenu = 1;
            //************
            if (Pos("Wat", PItem.Name, 0) > -1)
            {
              copy_P(HTMLString, AnswerGraph_1);
              return 1;
            };
            
            if (Pos("Dyn", PItem.Name, 0) > -1)
            {
              CreatPageForBrowserDyn(aIndex);
              return 1;
            };
            
            
            //*************
            ReadDataFromMemory(ValStr);
            
            copy_P(HTMLString + strlen(HTMLString), html_text_1);
            sprintf(HTMLString + strlen(HTMLString), "%s", PItem.Name);
            copy_P(HTMLString + strlen(HTMLString), html_text_2);
            sprintf(HTMLString + strlen(HTMLString), "%s", ValStr);
            copy_P(HTMLString + strlen(HTMLString), html_text_3);
            
        };
    };
    copy_P(HTMLString + strlen(HTMLString), html_end_1);
    
    return 1;
};
char CreatPageForBrowserDyn(int aIndex)
{
    int i;
    uint16_t byteSize;
    uint16_t x, y, maxX = 0, maxY = 0;
    
    ClearHTMLString();
    
    copy_P(HTMLString, AnswerDyn_1);
    
    //**********************
    outBuffer[0] = 4;
    outBuffer[1] = (uint8_t)(PItem.Adres >> 8); 
    outBuffer[2] = (uint8_t)(PItem.Adres & 0xFF);  
    outBuffer[3] = (uint8_t)(PItem.BitFieldCount >> 8);
    outBuffer[4] = (uint8_t)(PItem.BitFieldCount & 0xFF);
    //--------------------
    for (i = 0; i < 50; i++)
    {
      lufkinCardForce.pair[i].Position = 10;
      lufkinCardForce.pair[i].Load = (60000/50) * i  + 10;
    }
    for (i = 0; i < 50; i++)
    {
      lufkinCardForce.pair[i + 50].Position = (60000/50) * i + 10;
      lufkinCardForce.pair[i + 50].Load = (60000/50) * 50  + 10;
    }
   for (i = 0; i < 50; i++)
    {
      lufkinCardForce.pair[i + 100].Position = (60000/50) * 50 + 10;
      lufkinCardForce.pair[i + 100].Load = (60000/50) * (50 - i)  + 10;
    }    

   for (i = 0; i < 50; i++)
    {
      lufkinCardForce.pair[i + 150].Position = (60000/50) * (50 - i) + 10;
      lufkinCardForce.pair[i + 150].Load = 10;
    }    
    
    //----------------------
    
    if (modbusRegistersEdit(outBuffer, inBuffer, 1, &byteSize) != 0)
        return 0;
    
    //Ищем максимальное значение по х у
    for (i = 0; i < 200; i++)
    {
      
      x = inBuffer[17 + i * 4] * 256 + inBuffer[18 + i * 4];
      y = inBuffer[19 + i * 4] * 256 + inBuffer[20 + i * 4];
      if (x > maxX)
        maxX = x;
      if (y > maxY)
        maxY = y;
            
    };
    
    sprintf(HTMLString + strlen(HTMLString),"if (example.height/%d > example.width/%d)\r\n{\r\n", maxY, maxX);
    sprintf(HTMLString + strlen(HTMLString),"k = example.width/%d;\r\n",maxX);
    sprintf(HTMLString + strlen(HTMLString),"k1 = %d/example.width;\r\n",maxX);
    strcat(HTMLString, "}\r\nelse\r\n{\r\n");
    sprintf(HTMLString + strlen(HTMLString),"k = example.height/%d;\r\n",maxY);
    sprintf(HTMLString + strlen(HTMLString),"k1 = %d/example.height;\r\n}\r\n",maxY);
    strcat(HTMLString, "ctx.scale(k, k);\r\n");
    strcat(HTMLString, "ctx.beginPath();\r\n");

    x = inBuffer[17] * 256 + inBuffer[18];
    y = inBuffer[19] * 256 + inBuffer[20];
    //****************
                        
    sprintf(HTMLString + strlen(HTMLString),"ctx.moveTo(%d,%d);\r\n", x, y);
    for (i = 1; i < 200; i++)
    {
          
      x = inBuffer[17 + i * 4] * 256 + inBuffer[18 + i * 4];
      y = inBuffer[19 + i * 4] * 256 + inBuffer[20 + i * 4];
      sprintf(HTMLString + strlen(HTMLString),"ctx.lineTo(%d, %d);\r\n", x, y); 
      
    };
    strcat(HTMLString, "ctx.lineWidth = k1;\r\n");
    copy_P(HTMLString + strlen(HTMLString), AnswerDyn_2);
    
    return 1;
}
// страница с архивами для браузера
char CreatPageForBrowser_2(int aIndex)
{
    int i;
    // если пункт меню текущий то читаем последний индекс
    if (aIndex == 2)
        FlagReadLastArhiveIndex = 0;
    
    if (FlagReadLastArhiveIndex == 0)
    {
        LastArhiveIndex = GetLastIndexArhive();
        if (LastArhiveIndex < 0)
            return 0;
        FlagReadLastArhiveIndex = 1;
        if (LastArhiveIndex == 0) 
          CurrentArhiveIndex = MAX_ARHIVE_STACK - 1;
        else
          CurrentArhiveIndex = LastArhiveIndex - 1;
    };
       
    
    ClearHTMLString();

    
    if (ColorHtmlText == 0)
      copy_P(HTMLString, html_text_black);
    else
      copy_P(HTMLString, html_text_blue);

    //copy_P(HTMLString + strlen(HTMLString), html_method_get_1);
    //sprintf(HTMLString + strlen(HTMLString), "%d", aIndex);
    //copy_P(HTMLString + strlen(HTMLString), html_method_get_2);
        
    for (i = 0; i <= MAX_ARHIVE_STR - 1; i++)
    {
       CurrentMenu = 2;
       ReadDataFromArhive(ValStr, aIndex);
       copy_P(HTMLString + strlen(HTMLString), html_text_1);
       sprintf(HTMLString + strlen(HTMLString), "%d", CurrentArhiveIndex);
       copy_P(HTMLString + strlen(HTMLString), html_text_2);
       sprintf(HTMLString + strlen(HTMLString), "%s", ValStr);
       decodArhiv(ValData[5]);
       copy_P(HTMLString + strlen(HTMLString), html_text_3);
 
    };
    copy_P(HTMLString + strlen(HTMLString), html_end_2);
    
    return 1;
};

